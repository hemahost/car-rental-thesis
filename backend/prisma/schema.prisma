generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  passwordHash      String?
  phone             String?    @default("")
  address           String?    @default("")
  avatarUrl         String?    @default("")
  role              String     @default("USER")
  provider          String     @default("local")
  providerId        String?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean    @default(false)
  createdAt         DateTime   @default(now())
  bookings       Booking[]
  favorites      Favorite[]
  passwordResets PasswordReset[]
  reviews        Review[]
  conversations  ChatConversation[]
}

model Car {
  id           String     @id @default(cuid())
  brand        String
  model        String
  type         String
  pricePerDay  Float
  imageUrl     String?
  description  String
  city         String?
  seats        Int?
  transmission String?
  fuelType     String?
  year         Int?
  createdAt    DateTime   @default(now())
  bookings    Booking[]
  favorites   Favorite[]
  reviews     Review[]
}

model Booking {
  id               String   @id @default(cuid())
  userId           String
  carId            String
  startDate        DateTime
  endDate          DateTime
  totalPrice       Float
  status           String   @default("PENDING")
  paymentIntentId  String?
  paymentStatus    String   @default("UNPAID")
  pickupLocation   String?
  dropoffLocation  String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  car              Car      @relation(fields: [carId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model ChatConversation {
  id               String   @id @default(cuid())
  userId           String?
  message          String
  extractedFilters Json
  recommendations  Json
  aiResponse       String
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id])
}
